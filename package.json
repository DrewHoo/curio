{
  "name": "curio-worldcup-goals",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Which countries have scored the most World Cup goals — a cumulative race, one line per country, every point a real match. An example Curio.",
  "scripts": {
    "fetch": "node scripts/fetch-data.mjs",
    "dev": "vite",
    "build": "node scripts/fetch-data.mjs && tsc -b && vite build",
    "build:no-fetch": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
